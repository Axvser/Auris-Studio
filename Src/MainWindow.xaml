                          Click="Theme_Click" 
                          x:Name="ThemeButton"
                          ContentMargin="0"
                          Margin="30,0,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <v:MidiEditorView x:Name="Editor"
                              Grid.Row="1"
                              Background="{Binding ElementName=Main,Path=Background}"
                              Foreground="{Binding ElementName=Main,Path=Foreground}"/>
        </Grid>

        <Grid x:Name="ResizeOverlay"
              Grid.RowSpan="2"
              Panel.ZIndex="999">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=Main, Path=WindowState}" Value="Maximized">
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="6"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNWSE"
                       Tag="TopLeft"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNS"
                       Tag="Top"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="0"
                    Grid.Column="2"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNESW"
                       Tag="TopRight"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeWE"
                       Tag="Left"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="2"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeWE"
                       Tag="Right"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="2"
                    Grid.Column="0"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNESW"
                       Tag="BottomLeft"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="2"
                    Grid.Column="1"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNS"
                       Tag="Bottom"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
            <Border Grid.Row="2"
                    Grid.Column="2"
                    Background="#01FFFFFF">
                <Thumb Style="{StaticResource ResizeHitThumbStyle}"
                       Cursor="SizeNWSE"
                       Tag="BottomRight"
                       DragDelta="ResizeThumb_DragDelta"/>
            </Border>
        </Grid>
    </Grid>
</Window>
