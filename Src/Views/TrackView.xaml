<UserControl x:Class="Auris_Studio.Views.TrackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Auris_Studio.Views"
             HorizontalAlignment="Stretch"
             mc:Ignorable="d"
             d:DesignHeight="160" d:DesignWidth="280"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MidiTrackViewModel,IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <Style x:Key="TrackFieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=FieldBackground}"/>
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="TrackFieldButtonStyle" TargetType="local:Button">
            <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=FieldBackground}"/>
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=Foreground}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BlurRadius" Value="20"/>
            <Setter Property="ContentMargin" Value="12,8,12,8"/>
            <Setter Property="UseHoverForeground" Value="False"/>
        </Style>
    </UserControl.Resources>
    <Border x:Name="CardBorder"
            Margin="8,0,8,12"
            Padding="8,6"
            HorizontalAlignment="Stretch"
            CornerRadius="20"
            MouseLeftButtonDown="CardBorder_MouseLeftButtonDown"
            MouseEnter="CardBorder_MouseEnter"
            MouseLeave="CardBorder_MouseLeave">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background"
                        Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=CardBackground}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=SurfaceState}"
                                 Value="Hover">
                        <Setter Property="Background"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=HoverCardBackground}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=SurfaceState}"
                                 Value="Selected">
                        <Setter Property="Background"
                                Value="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=SelectedCardBackground}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NameTextBox"
                         Grid.Column="0"
                         MinWidth="0"
                         Style="{StaticResource TrackFieldTextBoxStyle}"
                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontWeight="SemiBold"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="8,0,0,0">
                    <local:Button x:Name="SoloButton"
                                  ButtonContent="S"
                                  Style="{StaticResource TrackFieldButtonStyle}"
                                  Width="40"
                                  Height="40"
                                  UseHoverBackground="False"
                                  Click="Solo_Click"/>
                    <local:Button x:Name="MuteButton"
                                  Margin="8,0,0,0"
                                  ButtonContent="M257.493333 322.4l215.573334-133.056c24.981333-15.413333 57.877333-7.914667 73.493333 16.746667 5.301333 8.373333 8.106667 18.048 8.106667 27.914666v555.989334C554.666667 819.093333 530.784 842.666667 501.333333 842.666667c-9.994667 0-19.786667-2.773333-28.266666-8L257.493333 701.6H160c-41.237333 0-74.666667-33.013333-74.666667-73.738667V396.138667c0-40.725333 33.429333-73.738667 74.666667-73.738667h97.493333z m26.133334 58.4a32.298667 32.298667 0 0 1-16.96 4.8H160c-5.888 0-10.666667 4.714667-10.666667 10.538667v231.733333c0 5.813333 4.778667 10.538667 10.666667 10.538667h106.666667c5.994667 0 11.872 1.664 16.96 4.8L490.666667 770.986667V253.013333L283.626667 380.8zM800.906667 829.653333a32.288 32.288 0 0 1-45.248-0.757333 31.317333 31.317333 0 0 1 0.768-44.693333c157.653333-150.464 157.653333-393.962667 0-544.426667a31.317333 31.317333 0 0 1-0.768-44.682667 32.288 32.288 0 0 1 45.248-0.757333c183.68 175.306667 183.68 460.010667 0 635.317333z m-106.901334-126.186666a32.288 32.288 0 0 1-45.248-1.216 31.328 31.328 0 0 1 1.237334-44.672c86.229333-80.608 86.229333-210.56 0-291.178667a31.328 31.328 0 0 1-1.237334-44.672 32.288 32.288 0 0 1 45.248-1.216c112.885333 105.546667 112.885333 277.418667 0 382.965333z"
                                  Style="{StaticResource TrackFieldButtonStyle}"
                                  Width="40"
                                  Height="40"
                                  UseHoverBackground="False"
                                  Click="Mute_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="ChannelLabel"
                           Grid.Row="0"
                           Grid.Column="0"
                           Text="Channel"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=SecondaryForeground}"
                           FontSize="11"/>
                <TextBlock x:Name="PatchLabel"
                           Grid.Row="1"
                           Grid.Column="0"
                           Text="Patch"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=SecondaryForeground}"
                           FontSize="11"
                           Margin="0,8,0,0"/>

                <local:Button x:Name="ChannelButton"
                              Grid.Row="0"
                              Grid.Column="1"
                              Margin="12,0,0,0"
                              Style="{StaticResource TrackFieldButtonStyle}"
                              HorizontalAlignment="Stretch"
                              Click="ChannelButton_Click"/>
                <local:Button x:Name="PatchButton"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="12,8,0,0"
                              Style="{StaticResource TrackFieldButtonStyle}"
                              HorizontalAlignment="Stretch"
                              Click="PatchButton_Click"/>
            </Grid>

            <Popup x:Name="ChannelPopup"
                   PlacementTarget="{Binding ElementName=ChannelButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border x:Name="ChannelPopupBorder"
                        Margin="0,8,0,0"
                        Padding="8"
                        CornerRadius="20"
                        Background="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=PopupBackground}"
                        BorderThickness="0"
                        Opacity="0.97">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.25"/>
                    </Border.Effect>
                    <ScrollViewer MaxHeight="260"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChannelOptionsPanel"/>
                    </ScrollViewer>
                </Border>
            </Popup>

            <Popup x:Name="PatchPopup"
                   PlacementTarget="{Binding ElementName=PatchButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border x:Name="PatchPopupBorder"
                        Margin="0,8,0,0"
                        Padding="8"
                        CornerRadius="20"
                        Background="{Binding RelativeSource={RelativeSource AncestorType=local:TrackView}, Path=PopupBackground}"
                        BorderThickness="0"
                        Opacity="0.97">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.25"/>
                    </Border.Effect>
                    <ScrollViewer MaxHeight="300"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PatchOptionsPanel"/>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
