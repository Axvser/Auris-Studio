<UserControl x:Class="Auris_Studio.Views.Workflow.BasicPitchConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views.Workflow"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels.Workflows"
             d:DataContext="{d:DesignInstance Type=vm:BasicPitchConfigViewModel,IsDesignTimeCreatable=True}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#4a76a8" Padding="8" CornerRadius="3">
            <TextBlock Text="音频转MIDI配置" 
                      FontSize="16" 
                      FontWeight="Bold" 
                      Foreground="White"/>
        </Border>

        <!-- 配置面板 -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 文件路径配置 -->
            <GroupBox Grid.Row="0" Header="文件路径" Padding="8" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 音频文件路径 -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="音频文件：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" 
                                Text="{Binding AudioFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,5,0"/>
                        <Button Grid.Column="2" 
                                Content="浏览" 
                                Command="{Binding BrowseAudioFileCommand}"
                                Padding="8,4" MinWidth="60"/>
                    </Grid>

                    <!-- 输出目录 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="输出目录：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" 
                                Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,5,0"/>
                        <Button Grid.Column="2" 
                                Content="浏览" 
                                Command="{Binding BrowseOutputDirectoryCommand}"
                                Padding="8,4" MinWidth="60"/>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- 处理选项 -->
            <GroupBox Grid.Row="1" Header="处理选项" Padding="8">
                <StackPanel>
                    <!-- 保存选项 -->
                    <CheckBox Content="保存MIDI文件" 
                            IsChecked="{Binding SaveMidi}" 
                            Margin="0,5"/>
                    <CheckBox Content="生成音频预览" 
                            IsChecked="{Binding SonifyMidi}" 
                            Margin="0,5"/>

                    <!-- 阈值参数 -->
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 起始阈值 -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="起始阈值：" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" 
                                   Minimum="0" 
                                   Maximum="1" 
                                   TickFrequency="0.1"
                                   Value="{Binding OnsetThreshold, Mode=TwoWay}"
                                   Margin="5,0"/>
                            <TextBlock Grid.Column="2" 
                                      Text="{Binding OnsetThreshold, StringFormat=F2}"
                                      Width="40" 
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 帧阈值 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="帧阈值：" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" 
                                   Minimum="0" 
                                   Maximum="1" 
                                   TickFrequency="0.1"
                                   Value="{Binding FrameThreshold, Mode=TwoWay}"
                                   Margin="5,0"/>
                            <TextBlock Grid.Column="2" 
                                      Text="{Binding FrameThreshold, StringFormat=F2}"
                                      Width="40" 
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 控制按钮区域 -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 重置按钮 -->
                <Button Grid.Column="0" 
                       Content="重置默认" 
                       Command="{Binding ResetToDefaultsCommand}"
                       HorizontalAlignment="Left"
                       Padding="10,6"/>

                <!-- 转换按钮 -->
                <Button Grid.Column="1" 
                       Content="开始转换" 
                       Command="{Binding ConvertCommand}"
                       Background="#4CAF50"
                       Foreground="White"
                       FontWeight="Bold"
                       Padding="15,8"
                       Margin="0,0,10,0"/>

                <!-- 取消按钮 -->
                <Button Grid.Column="2" 
                       Content="取消转换" 
                       Command="{Binding CancelCommand}"
                       Background="#F44336"
                       Foreground="White"
                       FontWeight="Bold"
                       Padding="10,8"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
