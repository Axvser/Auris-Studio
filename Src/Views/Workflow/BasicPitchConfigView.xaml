<UserControl x:Class="Auris_Studio.Views.Workflow.BasicPitchConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views.Workflow"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="200"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels.Workflows"
             xmlns:v="clr-namespace:Auris_Studio.Views"
             d:DataContext="{d:DesignInstance Type=vm:BasicPitchConfigViewModel,IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="ConfigTextBox">
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="ConfigCheckBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Slider" x:Key="ThresholdSlider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid.RowDefinitions>
            <!-- 紧凑型标题栏 -->
            <RowDefinition Height="30"/>
            <!-- 配置面板主体 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,5,5"
                BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <!-- 紧凑标题栏 -->
        <Border Grid.Row="0"
                Background="Transparent"
                MouseDown="OnMouseDown" 
                MouseUp="OnMouseUp" 
                MouseMove="OnMouseMove" 
                MouseLeave="OnMouseLeave"
                BorderThickness="1,1,1,0.5"
                CornerRadius="5,5,0,0"
                BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <TextBlock Text="basic-pitch config" 
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- 配置面板主体（包含左右连接点区域和内容区域） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左侧连接点区域 (15%宽度) -->
                <ColumnDefinition Width="0.15*"/>
                <!-- 中间内容区域 (70%宽度) -->
                <ColumnDefinition Width="0.7*"/>
                <!-- 右侧连接点区域 (15%宽度) -->
                <ColumnDefinition Width="0.15*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧连接点区域 -->
            <Border Grid.Column="0" Background="Transparent" x:Name="LeftConnectionArea">
                <!-- 连接点可视化元素可在此添加 -->
            </Border>

            <!-- 中间内容区域（可滚动） -->
            <Grid Grid.Column="1">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="音频文件:"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"
                                   Margin="0,5,0,2"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding AudioFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ConfigTextBox}"/>
                            <v:Button Grid.Column="1"
                                      ButtonContent="浏览"
                                      Command="{Binding BrowseAudioFileCommand}"
                                      Margin="5,0,0,0"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <!-- 输出目录配置 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="输出目录:"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,2"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ConfigTextBox}"/>
                            <v:Button Grid.Column="1"
                                      ButtonContent="浏览"
                                      Command="{Binding BrowseOutputDirectoryCommand}"
                                      Margin="5,0,0,0"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>

                    <!-- 核心参数配置 -->
                    <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            BorderThickness="0,1,0,0"
                            Padding="0,5,0,5"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="核心参数:"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>

                            <!-- Minimum Note Length 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="最小音符长度 (ms):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0.0" 
                                            Maximum="500.0" 
                                            Value="{Binding MinimumNoteLength}"
                                            SmallChange="1.0"
                                            LargeChange="10.0"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding MinimumNoteLength, StringFormat=N1}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="40"/>
                                </Grid>
                            </Grid>

                            <!-- Minimum Frequncy 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="最低频率 (Hz):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="8.18" 
                                            Maximum="12543.85" 
                                            Value="{Binding MinimumFrequency}"
                                            SmallChange="1.0"
                                            LargeChange="10.0"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding MinimumFrequency, StringFormat=N2}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="40"/>
                                </Grid>
                            </Grid>

                            <!-- Maximum Frequency 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="最高频率 (Hz):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="8.18" 
                                            Maximum="12543.85" 
                                            Value="{Binding MaximumFrequency}"
                                            SmallChange="1.0"
                                            LargeChange="10.0"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding MaximumFrequency, StringFormat=N2}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="40"/>
                                </Grid>
                            </Grid>

                            <!-- Samplerate 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="采样率 (Hz):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0" 
                                            Maximum="200000" 
                                            Value="{Binding Samplerate}"
                                            SmallChange="1.0"
                                            LargeChange="10.0"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Samplerate, StringFormat=N0}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="40"/>
                                </Grid>
                            </Grid>

                            <!-- Tempo 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="Tempo:"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0"
                                            Maximum="400"
                                            Value="{Binding Tempo}"
                                            SmallChange="1.0"
                                            LargeChange="10.0"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Tempo, StringFormat=N0}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="40"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="{Binding Foreground,RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <!-- 其它参数配置 -->
                        <StackPanel Margin="0,5,0,0">

                            <TextBlock Text="检测力度参数:"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   VerticalAlignment="Center"
                                   Margin="0,5,0,2"/>

                            <!-- Onset Threshold 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="起始检测阈值 (Onset):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0.0" 
                                            Maximum="1.0" 
                                            Value="{Binding OnsetThreshold}"
                                            SmallChange="0.01"
                                            LargeChange="0.1"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="False"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding OnsetThreshold, StringFormat=N2}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="30"/>
                                </Grid>
                            </Grid>

                            <!-- Frame Threshold 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="帧阈值 (Frame):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0.0" 
                                            Maximum="1.0" 
                                            Value="{Binding FrameThreshold}"
                                            SmallChange="0.01"
                                            LargeChange="0.1"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="False"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding FrameThreshold, StringFormat=N2}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="30"/>
                                </Grid>
                            </Grid>

                            <!-- DefChannel 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="默认通道 (Channel):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="1"
                                            Maximum="16" 
                                            Value="{Binding DefChannel}"
                                            SmallChange="1"
                                            LargeChange="1"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="False"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DefChannel, StringFormat=N0}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="30"/>
                                </Grid>
                            </Grid>

                            <!-- DefPatch 滑动条 -->
                            <Grid Margin="0,0,0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" 
                                           Text="默认音色 (Patch):"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Margin="0,0,0,2"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" 
                                            Minimum="0"
                                            Maximum="127" 
                                            Value="{Binding DefPatch}"
                                            SmallChange="1"
                                            LargeChange="1"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="False"
                                            Style="{StaticResource ThresholdSlider}"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DefPatch, StringFormat=N0}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               MinWidth="30"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 右侧连接点区域 -->
            <Border Grid.Column="2" Background="Transparent" x:Name="RightConnectionArea">
                <!-- 连接点可视化元素可在此添加 -->
            </Border>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2">
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Offset.Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Offset.Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SlotViewModel}">
                        <local:SlotView Width="{Binding Size.Width}"
                                        Height="{Binding Size.Height}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
