<UserControl x:Class="Auris_Studio.Views.PianoSlidingDoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="400"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MidiEditorViewModel,IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 顶侧刻度线（带文本） -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Hidden"
                              x:Name="TopCuttingLinesScrollViewer">
                    <ItemsControl ItemsSource="{Binding CuttingLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="{Binding CanvasWidth}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Line X1="0" X2="0" 
                                          Y1="0" Y2="20"
                                          Stroke="Gray" 
                                          StrokeThickness="{Binding Width}"/>
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="9"
                                               Foreground="DarkGray"
                                               VerticalAlignment="Top"
                                               Visibility="{Binding Text, TargetNullValue=Collapsed, FallbackValue=Collapsed}">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="45"/>
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 钢琴卷帘门绘制 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- 钢琴按键绘制 -->
            <Grid Grid.Column="0">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Hidden"
                              x:Name="PianoKeysScrollViewer">
                    <ItemsControl ItemsSource="{Binding PianoKeys}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Height="{Binding NotesCanvasHeight}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Bottom" Value="{Binding Bottom}" />
                                <Setter Property="Canvas.ZIndex" Value="{Binding Layer}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:PianoKeyView Text="{Binding Text}"
                                                    Type="{Binding Type}"
                                                    Height="{Binding Height}"
                                                    HorizontalAlignment="Left"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="15"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <!-- 轨道背景绘制 -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  x:Name="BackDrawLineScrollViewer"
                                  Focusable="False">
                        <ItemsControl ItemsSource="{Binding VisualTracks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Height="{Binding NotesCanvasHeight}"
                                            Width="{Binding CanvasWidth}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Bottom" Value="{Binding Bottom}" />
                                    <Setter Property="Canvas.ZIndex" Value="{Binding Layer}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:TrackBackgroundView Type="{Binding Type}"
                                                               Height="{Binding Height}"
                                                               Width="{Binding RelativeSource={RelativeSource AncestorType=local:PianoSlidingDoorView},Path=DataContext.CanvasWidth}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 中部刻度线（不带文本） -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Hidden"
                              x:Name="CenterCuttingLinesScrollViewer">
                        <ItemsControl ItemsSource="{Binding CuttingLines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding CanvasWidth}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="0" X2="0" 
                                          Y1="0" Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                          Stroke="LightGray" 
                                          StrokeThickness="{Binding Width}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                     <!-- 音符绘制 -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  x:Name="NotesScrollViewer"
                                  SizeChanged="NotesScrollViewer_SizeChanged">
                        <ItemsControl ItemsSource="{Binding CurrentNotes}"
                                      Height="{Binding NotesCanvasHeight}"
                                      Width="{Binding CanvasWidth}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Height="{Binding NotesCanvasHeight}"
                                            Width="{Binding CanvasWidth}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    <Setter Property="Canvas.Bottom" Value="{Binding Bottom}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:NoteView Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    Background="Orange"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                <Grid Grid.Column="1">
                    <local:ScrollBar x:Name="VerticalScrollBar"
                                     Minimum="0"
                                     Maximum="{Binding NotesCanvasHeight}"
                                     ViewportSize="{Binding ElementName=NotesScrollViewer,Path=ViewportHeight}"
                                     OffsetChanged="VerticalScrollBar_OffsetChanged"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
