<UserControl x:Class="Auris_Studio.Views.MidiEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MidiEditorViewModel,IsDesignTimeCreatable=True}"
             x:Name="Root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- 编辑器头栏 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Button Content="File" Click="SelectMidi_Click"/>
                <Button Content="Diagnose" Click="Diagnose_Click"/>
                <Button Content="Theme" Click="Theme_Click" />
            </StackPanel>
        </Grid>

        <!-- 编辑器中栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- 音轨列表，竖轴与横轴仅在可滑动时显示 -->
            <Grid Grid.Column="0">

            </Grid>

            <Grid Grid.Column="1">
                <local:PianoSlidingDoorView x:Name="PianoSlidingDoorView"
                                            DataContext="{Binding ElementName=Root,Path=DataContext}" />
            </Grid>
        </Grid>

        <!-- 编辑器底栏 -->
        <Grid Grid.Row="2">
            <Viewbox>
                <TextBlock Text="{Binding ViewportTop}"
                           Foreground="{Binding ElementName=Root,Path=Foreground}"/>
            </Viewbox>
        </Grid>
    </Grid>
</UserControl>