<UserControl x:Class="Auris_Studio.Views.MidiEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             xmlns:v="clr-namespace:Auris_Studio.Views"
             xmlns:v_wk="clr-namespace:Auris_Studio.Views.Workflow"
             d:DataContext="{d:DesignInstance Type=vm:MidiEditorViewModel,IsDesignTimeCreatable=True}"
             x:Name="Root">
    <UserControl.Resources>
        <Style TargetType="local:Button">
            <Setter Property="ContentMargin" Value="14,10,14,10"/>
            <Setter Property="BlurRadius" Value="20"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="1*" MaxHeight="50"/>
        </Grid.RowDefinitions>

        <!-- 编辑器头栏 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <local:Button ButtonContent="Import"
                              Click="Import_Click"/>
                <local:Button ButtonContent="Export"
                              Click="Export_Click"/>
                <local:Button ButtonContent="Diagnose"
                              Click="Diagnose_Click"/>
                <local:Button x:Name="Component"
                              ButtonContent="AI Pipeline"
                              Click="Component_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <local:Button ButtonContent="Theme" 
                              Click="Theme_Click" />
            </StackPanel>
        </Grid>

        <!-- 编辑器中栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- 音轨列表，竖轴与横轴仅在可滑动时显示 -->
            <Grid Grid.Column="0">

            </Grid>

            <Grid Grid.Column="1">
                <local:PianoSlidingDoorView x:Name="PianoSlidingDoorView"
                                            DataContext="{Binding ElementName=Root,Path=DataContext}"
                                            Background="{Binding ElementName=Root,Path=Background}"
                                            Foreground="{Binding ElementName=Root,Path=Foreground}"/>
            </Grid>
        </Grid>

