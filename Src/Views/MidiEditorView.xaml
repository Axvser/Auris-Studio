<UserControl x:Class="Auris_Studio.Views.MidiEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             xmlns:v="clr-namespace:Auris_Studio.Views"
             xmlns:v_wk="clr-namespace:Auris_Studio.Views.Workflow"
             d:DataContext="{d:DesignInstance Type=vm:MidiEditorViewModel,IsDesignTimeCreatable=True}"
             x:Name="Root"
             SizeChanged="Root_SizeChanged">
    <UserControl.Resources>
        <Style TargetType="local:Button">
            <Setter Property="ContentMargin" Value="14,10,14,10"/>
            <Setter Property="BlurRadius" Value="20"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="1*" MaxHeight="50"/>
        </Grid.RowDefinitions>

        <!-- 编辑器头栏 -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <local:Button x:Name="TracksButton"
                              ButtonContent="▶ Tracks"
                              Click="Tracks_Click"/>
                <local:Button x:Name="ImportButton"
                              ButtonContent="Import"
                              Click="Import_Click"/>
                <local:Button x:Name="ExportButton"
                              ButtonContent="Export"
                              Click="Export_Click"/>
                <local:Button x:Name="DiagnoseButton"
                              ButtonContent="Diagnose"
                              Click="Diagnose_Click"/>
                <local:Button x:Name="Component"
                              ButtonContent="AI Pipeline"
                              Click="Component_Click"/>
                <CheckBox Margin="16,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding UseSnap, Mode=TwoWay}"
                          Foreground="{Binding ElementName=Root,Path=Foreground}"
                          Content="Snap"/>
                <ComboBox Width="140"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding DragBehavior, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBoxItem Content="Drag: Free"
                                  Tag="{x:Static vm:NoteDragBehavior.Free}"/>
                    <ComboBoxItem Content="Drag: Horizontal"
                                  Tag="{x:Static vm:NoteDragBehavior.HorizontalPriority}"/>
                    <ComboBoxItem Content="Drag: Vertical"
                                  Tag="{x:Static vm:NoteDragBehavior.VerticalPriority}"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- 编辑器中栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <!-- 音轨列表，竖轴与横轴仅在可滑动时显示 -->
            <Grid Grid.Column="0">
                <local:TrackListView x:Name="TrackView"
                                     Width="0"
                                     Visibility="Hidden"
                                     DataContext="{Binding ElementName=Root,Path=DataContext}"
                                     Background="{Binding ElementName=Root,Path=Background}"
                                     Foreground="{Binding ElementName=Root,Path=Foreground}"/>
            </Grid>
            <!-- 钢琴卷帘门 -->
            <Grid Grid.Column="1">
                <local:PianoSlidingDoorView x:Name="PianoSlidingDoorView"
                                            DataContext="{Binding ElementName=Root,Path=DataContext}"
                                            Background="{Binding ElementName=Root,Path=Background}"
                                            Foreground="{Binding ElementName=Root,Path=Foreground}"/>
            </Grid>
        </Grid>

        <!-- 编辑器底栏 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <v:Button ButtonContent="M912.724884 429.355681L208.797545 13.198638C151.603449-20.597874 64.01249 12.198741 64.01249 95.790112V927.904219c0 74.992259 81.391599 120.187594 144.785055 82.591475l703.927339-415.957064c62.793518-36.996181 62.993498-128.186768 0-165.182949z"
                      Command="{Binding PlayCommand}"
                      x:Name="PlayButton"
                      Grid.Column="5"
                      UseHoverBackground="False"
                      ContentMargin="10"/>
            <Grid Grid.Column="7">
                <Viewbox>
                    <TextBlock Text="{Binding CurrentTimeSpan, StringFormat={}{0:m\\:ss\\.fff}}"
                               Foreground="{Binding ElementName=Root,Path=Foreground}"/>
                </Viewbox>
            </Grid>
            <Grid Grid.Column="6">
                <local:Button ButtonContent="M343.134964 724.45563a44.688952 44.688952 0 0 0 11.721692-12.362723 115.38541 115.38541 0 0 0 9.157572-17.033084c2.56412-6.135573 5.12824-12.454298 7.783937-19.04775l32.051502-81.410817h206.961132l42.949014 108.242503a44.872104 44.872104 0 0 0 12.087995 19.505629 28.571625 28.571625 0 0 0 21.520295 6.685028c13.553207 0 22.161325-3.937756 25.824354-11.721693a36.630289 36.630289 0 0 0-0.824182-28.571625l-164.8363-433.611044a35.165077 35.165077 0 0 0-14.102661-18.315145 47.344648 47.344648 0 0 0-26.556959-6.685028 43.681619 43.681619 0 0 0-25.366475 6.685028 35.439804 35.439804 0 0 0-13.736359 18.315145L303.665827 687.275886c-5.677695 16.025751-5.677695 27.472717 0 32.875685a32.143078 32.143078 0 0 0 24.267567 9.157572 26.190657 26.190657 0 0 0 15.20157-4.853513zM507.696536 302.199975l89.011602 242.584088H418.593359z M754.401532 910.629073a462.640548 462.640548 0 0 1-657.42211-191.576411 468.501395 468.501395 0 0 1 2.380969-426.926017v-0.732605a19.68878 19.68878 0 0 0 1.556787-6.776604 22.619203 22.619203 0 0 0-22.619203-22.527628 21.795022 21.795022 0 0 0-21.062416 15.018419A526.1941 526.1941 0 0 0 0.000733 503.666563V511.999954a509.344167 509.344167 0 0 0 109.341412 316.210969l4.578786 5.76927a511.084105 511.084105 0 0 0 397.988089 190.019624H523.081258a509.985197 509.985197 0 0 0 253.481599-74.817365l30.128412 51.923434L836.728106 888.284597l-112.546562-29.853686z m160.165938-714.840087c-1.465212-1.92309-3.021999-3.754605-4.578786-5.677695A511.084105 511.084105 0 0 0 511.90902 0.000092h-11.263814A509.06944 509.06944 0 0 0 247.255182 75.000608l-30.128412-52.01501-29.945261 112.546562 112.546562 30.036837-30.219988-52.289737a462.548973 462.548973 0 0 1 657.422109 191.667986 468.318243 468.318243 0 0 1-2.014666 426.834441V732.605869a20.696113 20.696113 0 0 0-1.556787 6.776603 22.710779 22.710779 0 0 0 22.619204 22.619204 21.886598 21.886598 0 0 0 21.062416-15.109994 526.1941 526.1941 0 0 0 57.14325-226.558337v-0.64103-7.600785a509.06944 509.06944 0 0 0-109.616139-316.302544z"
                              Click="FollowMode_Click"
                              x:Name="FollowButton"
                              UseHoverBackground="False"/>
            </Grid>
        </Grid>

        <!-- 工作流配置 -->
        <Grid Grid.Row="1" Grid.RowSpan="2">
            <v_wk:AIPipelineView x:Name="AIPipelineView" 
                                 Grid.RowSpan="2"
                                 Visibility="Hidden"
                                 DataContext="{Binding AIPipeline}"
                                 Background="{Binding ElementName=Root,Path=Background}"
                                 Foreground="{Binding ElementName=Root,Path=Foreground}"/>
        </Grid>
    </Grid>
</UserControl>