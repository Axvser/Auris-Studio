<UserControl x:Class="Auris_Studio.Views.MidiEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             xmlns:vm="clr-namespace:Auris_Studio.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MidiEditorViewModel,IsDesignTimeCreatable=True}">
    <UserControl.Template>
        <ControlTemplate>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <!-- 编辑器头栏 -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="File" Click="SelectMidi_Click"/>
                        <Button Content="Diagnose" Click="Diagnose_Click"/>
                        <Button Content="Theme" Click="Theme_Click" />
                    </StackPanel>
                </Grid>

                <!-- 编辑器中栏 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <!-- 音轨列表，竖轴与横轴仅在可滑动时显示 -->
                    <Grid Grid.Column="0">

                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="0.618*"/>
                        </Grid.RowDefinitions>
                        <!-- 钢琴卷帘门 -->
                        <Grid Grid.Row="0">
                            <local:PianoSlidingDoorView x:Name="PianoSlidingDoorView"
                                                        DataContext="{TemplateBinding DataContext}" 
                                                        HorizontalOffset="{Binding ElementName=ControllerView,Path=HorizontalOffset,Mode=OneWay}"/>
                        </Grid>
                        <GridSplitter Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{TemplateBinding Background}"/>
                        <!-- 控制器 -->
                        <Grid Grid.Row="2">
                            <local:ControllerView x:Name="ControllerView" 
                                                  DataContext="{TemplateBinding DataContext}"
                                                  HorizontalViewportWidth="{Binding ElementName=PianoSlidingDoorView,Path=HorizontalViewportWidth,Mode=OneWay}"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 编辑器底栏 -->
                <Grid Grid.Row="2">
                    <Viewbox>
                        <TextBlock Text="{Binding CurrentNotes.Count}"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Viewbox>
                </Grid>
            </Grid>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>