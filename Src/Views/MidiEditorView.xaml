                          Click="ToMostRight_Click"
                          UseHoverBackground="False"
                          ContentMargin="5"/>
            <Grid Grid.Column="7">
                <Viewbox>
                    <TextBlock Text="{Binding CurrentTimeSpan, StringFormat={}{0:m\\:ss\\.fff}}"
                               Foreground="{Binding ElementName=Root,Path=Foreground}"/>
                </Viewbox>
            </Grid>
        </Grid>

        <!-- 工作流配置 -->
        <Grid Grid.Row="1" Grid.RowSpan="2">
            <v_wk:AIPipelineView x:Name="AIPipelineView" 
                                 Grid.RowSpan="2"
                                 Visibility="Hidden"
                                 DataContext="{Binding AIPipeline}"
                                 Background="{Binding ElementName=Root,Path=Background}"
                                 Foreground="{Binding ElementName=Root,Path=Foreground}"/>
        </Grid>
    </Grid>
</UserControl>