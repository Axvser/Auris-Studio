<UserControl x:Class="Auris_Studio.Views.ToolbarMenuItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="180"
             Background="#00000000">
    <Border x:Name="HoverLayer"
            Background="Transparent"
            CornerRadius="16"
            MouseEnter="HoverLayer_MouseEnter"
            MouseLeave="HoverLayer_MouseLeave"
            MouseLeftButtonUp="HoverLayer_MouseLeftButtonUp">
        <TextBlock x:Name="ContentText"
                   Margin="16,10"
                   VerticalAlignment="Center"
                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Foreground}"
                   Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Text}"
                   TextTrimming="CharacterEllipsis"/>
    </Border>
</UserControl>
