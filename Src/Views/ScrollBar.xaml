<UserControl x:Class="Auris_Studio.Views.ScrollBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Auris_Studio.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="RootGrid">
        <Canvas x:Name="MainCanvas">
            <!-- 轨道背景 -->
            <Border x:Name="TrackBackground" 
                    Background="Transparent"
                    MouseDown="OnTrackMouseDown"/>

            <!-- 按钮A（顶部/左侧）- 三角形 -->
            <Path x:Name="ButtonA" 
                  Fill="{Binding RelativeSource={RelativeSource AncestorType=local:ScrollBar},Path=Fill}"
                  Stroke="Transparent"
                  MouseDown="ButtonA_MouseDown"
                  Cursor="Hand">
                <Path.Data>
                    <!-- 初始方向：向上箭头（用于垂直滚动条的顶部） -->
                    <PathGeometry>
                        <PathFigure StartPoint="0,1">
                            <LineSegment Point="0.5,0"/>
                            <LineSegment Point="1,1"/>
                            <LineSegment Point="0,1"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- 可拖动的滑块 -->
            <Border x:Name="DragBar" 
                    Background="{Binding RelativeSource={RelativeSource AncestorType=local:ScrollBar},Path=Fill}"
                    MouseDown="DragBar_MouseDown"
                    Cursor="SizeNS"/>

            <!-- 按钮B（底部/右侧）- 三角形 -->
            <Path x:Name="ButtonB" 
                  Fill="{Binding RelativeSource={RelativeSource AncestorType=local:ScrollBar},Path=Fill}"
                  Stroke="Transparent"
                  MouseDown="ButtonB_MouseDown"
                  Cursor="Hand">
                <Path.Data>
                    <!-- 初始方向：向下箭头（用于垂直滚动条的底部） -->
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="0.5,1"/>
                            <LineSegment Point="1,0"/>
                            <LineSegment Point="0,0"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Canvas>
    </Grid>
</UserControl>
